@model List<FoodFlow.ViewModels.CartItemViewModel>
@{
    ViewData["Title"] = "Cart";
    var total = Model.Sum(x => x.LineTotal);
    var portionCount = Model.Sum(x => x.Quantity);
    var lineCount = Model.Count;
}
<h2 class="ff-title">Cart</h2>
<p class="ff-subtitle mb-3">Review your order before checkout.</p>
@if (TempData["CartMessage"] is string message)
{
    <div class="alert alert-warning">@message</div>
}
@if (!Model.Any())
{
    <div class="ff-surface-card p-4">
        <p class="mb-3">Your cart is empty.</p>
        <a class="btn btn-primary" asp-controller="Menu" asp-action="Index">Go to Menu</a>
    </div>
}
else
{
    <div class="row g-4 align-items-start">
        <div class="col-lg-8">
            <div class="ff-surface-card p-3 p-md-4">
                <h3 class="h5 mb-3">Your order</h3>
                <div class="table-responsive">
                    <table class="table align-middle mb-0">
                        <thead>
                            <tr>
                                <th>Dish</th>
                                <th class="text-end">Price</th>
                                <th class="text-end">Qty</th>
                                <th class="text-end">Total</th>
                                <th></th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var item in Model)
                            {
                                <tr>
                                    <td><strong>@item.Name</strong></td>
                                    <td class="text-end">$@item.UnitPrice.ToString("0.00")</td>
                                    <td class="text-end">@item.Quantity</td>
                                    <td class="text-end fw-semibold">$@item.LineTotal.ToString("0.00")</td>
                                    <td class="text-end">
                                        <form method="post" asp-controller="Cart" asp-action="Remove" class="d-inline">
                                            @Html.AntiForgeryToken()
                                            <input type="hidden" name="menuItemId" value="@item.MenuItemId" />
                                            <button type="submit" class="btn btn-sm btn-outline-danger">Remove</button>
                                        </form>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
        <div class="col-lg-4">
            <div class="ff-cart-summary ff-surface-card p-4">
                <h3 class="h5 mb-2">Order summary</h3>
                <p class="small text-muted mb-3">
                    @lineCount dish line(s) · @portionCount portion(s)
                </p>
                <div class="ff-cart-summary-row d-flex justify-content-between mb-2">
                    <span class="text-muted">Subtotal</span>
                    <span class="fw-semibold">$@total.ToString("0.00")</span>
                </div>
                <div class="ff-cart-summary-total d-flex justify-content-between align-items-baseline pt-3 mt-3">
                    <span class="fw-bold">Total</span>
                    <span class="fs-4 fw-bold">$@total.ToString("0.00")</span>
                </div>
                <div class="d-grid gap-2 mt-4">
                    <a class="btn btn-success" asp-controller="Cart" asp-action="Checkout">Checkout</a>
                    <a class="btn btn-outline-primary" asp-controller="Menu" asp-action="Index">Continue shopping</a>
                </div>
                <form method="post" asp-controller="Cart" asp-action="Clear" class="mt-3">
                    @Html.AntiForgeryToken()
                    <button type="submit" class="btn btn-link text-danger p-0 small text-decoration-none">Clear cart</button>
                </form>
            </div>
        </div>
    </div>
}