@{
    ViewData["Title"] = "Access denied";
}

<div class="ff-surface-card p-4 p-md-5 text-center">
    <h1 class="display-6 text-danger mb-3">Access denied</h1>
    <p class="ff-subtitle mb-4">
        You do not have permission to open this page with the current account.
    </p>
    <div class="d-flex justify-content-center flex-wrap gap-2">
        <a class="btn btn-primary" asp-area="Identity" asp-page="/Account/Login">Login with another account</a>
        <a class="btn btn-outline-secondary" asp-controller="Home" asp-action="Index">Go home</a>
    </div>
</div>
