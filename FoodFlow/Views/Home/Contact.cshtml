@{
    ViewData["Title"] = "Contact";
}

<h1 class="ff-title">Contact</h1>
<p class="ff-subtitle mb-4">Reach the restaurant team for orders, catering, or feedback.</p>

<div class="row g-4">
    <div class="col-lg-6">
        <div class="ff-surface-card p-4 ff-contact-block h-100">
            <h2 class="h5 mb-3">Visit us</h2>
            <p class="mb-2"><strong>FoodFlow Bistro</strong></p>
            <p class="text-muted mb-0">123 Sample Street, City</p>
            <p class="text-muted">Mon–Sun: 11:00 – 22:00</p>
        </div>
    </div>
    <div class="col-lg-6">
        <div class="ff-surface-card p-4 ff-contact-block h-100">
            <h2 class="h5 mb-3">Get in touch</h2>
            <p class="mb-2">Phone: <a href="tel:+15551234567">+1 (555) 123-4567</a></p>
            <p class="mb-0">Email: <a href="mailto:hello@foodflow.example">hello@foodflow.example</a></p>
        </div>
    </div>
</div>

<div class="ff-surface-card p-4 mt-4">
    <h2 class="h5 mb-3">Delivery & pickup</h2>
    <p class="text-muted mb-0">
        Order online through <a asp-controller="Menu" asp-action="Index">Menu</a> and <a asp-controller="Cart" asp-action="Index">Cart</a>.
        Average prep time depends on kitchen line portions — see dish cards on the home page.
    </p>
</div>
