@model FoodFlow.ViewModels.StockIndexViewModel
@using FoodFlow.Enums
@using System.Globalization

@{
    ViewData["Title"] = "Stock Management";

    var productsByLetter = Model.Products
        .GroupBy(p =>
        {
            var n = p.Name;
            if (string.IsNullOrEmpty(n)) return "[";
            var c = char.ToUpperInvariant(n[0]);
            return char.IsLetter(c) ? c.ToString() : "[";
        })
        .OrderBy(g => g.Key)
        .ToList();

    var menuByCategory = Model.MenuItems
        .GroupBy(m => new
        {
            Label = m.Category?.Name ?? "Without category",
            Sort = m.Category?.SortOrder ?? 999
        })
        .OrderBy(g => g.Key.Sort)
        .ThenBy(g => g.Key.Label)
        .ToList();

    var recipeByDish = Model.RecipeIngredients
        .GroupBy(ri => ri.MenuItemId)
        .Select(g => new
        {
            Dish = g.First().MenuItem,
            Rows = g.OrderBy(x => x.Product!.Name).ToList()
        })
        .OrderBy(x => x.Dish?.Category?.SortOrder ?? 999)
        .ThenBy(x => x.Dish?.Name ?? "")
        .ToList();
}

<h1 class="ff-title">Stock Management</h1>
<p class="ff-subtitle mb-3">Manage products, recipe ingredients, and stock operations.</p>

@if (TempData["StockMessage"] is string ok)
{
    <div class="alert alert-success">@ok</div>
}
@if (TempData["StockError"] is string err)
{
    <div class="alert alert-danger">@err</div>
}

<div class="row g-3 mb-4">
    <div class="col-lg-5">
        <div class="ff-surface-card h-100">
            <div class="card-body">
                <h5 class="card-title mb-3">Add product</h5>
                <form method="post" asp-action="AddProduct">
                    @Html.AntiForgeryToken()
                    <div class="mb-3">
                        <label class="form-label">Name</label>
                        <input name="name" class="form-control" placeholder="Tomato" />
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Unit</label>
                        <input name="unit" class="form-control" placeholder="g / ml / pcs" value="g" />
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Reorder level</label>
                        <input name="reorderLevel" type="number" step="0.001" min="0" class="form-control" value="0" />
                    </div>
                    <button type="submit" class="btn btn-primary">Add product</button>
                </form>
            </div>
        </div>
    </div>

    <div class="col-lg-7">
        <div class="ff-surface-card h-100">
            <div class="card-body">
                <h5 class="card-title mb-3">Stock operation</h5>
                <form method="post" asp-action="ApplyOperation">
                    @Html.AntiForgeryToken()
                    <div class="mb-3">
                        <label class="form-label">Product</label>
                        <select name="productId" class="form-select ff-stock-select" title="Grouped A–Z">
                            @foreach (var letterGroup in productsByLetter)
                            {
                                var label = letterGroup.Key == "[" ? "0–9 & other" : letterGroup.Key;
                                <optgroup label="@label">
                                    @foreach (var p in letterGroup.OrderBy(x => x.Name))
                                    {
                                        <option value="@p.Id">@p.Name — @p.QuantityInStock.ToString("0.###", CultureInfo.InvariantCulture) @p.Unit</option>
                                    }
                                </optgroup>
                            }
                        </select>
                    </div>

                    <div class="row g-2">
                        <div class="col-md-4">
                            <label class="form-label">Type</label>
                            <select name="type" class="form-select">
                                <option value="@StockTransactionType.Incoming">Incoming</option>
                                <option value="@StockTransactionType.WriteOff">Write-off</option>
                                <option value="@StockTransactionType.Adjustment">Adjustment</option>
                            </select>
                        </div>
                        <div class="col-md-4">
                            <label class="form-label">Quantity</label>
                            <input name="quantity" type="number" step="0.001" min="0" class="form-control" value="0" />
                        </div>
                        <div class="col-md-4">
                            <label class="form-label">Comment</label>
                            <input name="comment" class="form-control" placeholder="Optional" />
                        </div>
                    </div>

                    <button type="submit" class="btn btn-success mt-3">Apply operation</button>
                </form>
            </div>
        </div>
    </div>
</div>

<div class="ff-surface-card mb-4">
    <div class="card-body">
        <h5 class="card-title mb-3">Recipe setup</h5>
        <form method="post" asp-action="AddRecipeIngredient" class="row g-2 align-items-end">
            @Html.AntiForgeryToken()
            <div class="col-md-4">
                <label class="form-label">Dish</label>
                <select name="menuItemId" class="form-select ff-stock-select" title="By menu category">
                    @foreach (var cg in menuByCategory)
                    {
                        <optgroup label="@cg.Key.Label">
                            @foreach (var m in cg.OrderBy(x => x.Name))
                            {
                                <option value="@m.Id">@m.Name</option>
                            }
                        </optgroup>
                    }
                </select>
            </div>
            <div class="col-md-4">
                <label class="form-label">Ingredient</label>
                <select name="productId" class="form-select ff-stock-select" title="Grouped A–Z">
                    @foreach (var letterGroup in productsByLetter)
                    {
                        var label = letterGroup.Key == "[" ? "0–9 & other" : letterGroup.Key;
                        <optgroup label="@label">
                            @foreach (var p in letterGroup.OrderBy(x => x.Name))
                            {
                                <option value="@p.Id">@p.Name (@p.Unit)</option>
                            }
                        </optgroup>
                    }
                </select>
            </div>
            <div class="col-md-2">
                <label class="form-label">Amount/dish</label>
                <input name="amountPerDish" type="number" step="0.001" min="0.001" class="form-control" value="1" />
            </div>
            <div class="col-md-2">
                <button type="submit" class="btn btn-primary w-100">Save</button>
            </div>
        </form>
    </div>
</div>

<div class="ff-surface-card mb-4">
    <div class="card-body">
        <h5 class="card-title mb-3">Recipe ingredients</h5>
        <p class="small text-muted mb-3">One block per dish — expand to see all ingredients. Sorted by menu category, then dish name.</p>
        @if (!Model.RecipeIngredients.Any())
        {
            <p class="text-center text-muted mb-0">No recipe ingredients yet.</p>
        }
        else
        {
            <div class="accordion ff-recipe-accordion" id="recipeAccordion">
                @{
                    var accIdx = 0;
                }
                @foreach (var block in recipeByDish)
                {
                    var dish = block.Dish;
                    var dishId = dish?.Id ?? 0;
                    var headingId = $"h-rec-{dishId}";
                    var collapseId = $"c-rec-{dishId}";
                    var expanded = accIdx == 0;
                    accIdx++;
                    <div class="accordion-item border rounded mb-2 overflow-hidden">
                        <h2 class="accordion-header" id="@headingId">
                            <button class="accordion-button @(expanded ? "" : "collapsed")" type="button" data-bs-toggle="collapse" data-bs-target="#@collapseId" aria-expanded="@(expanded ? "true" : "false")" aria-controls="@collapseId">
                                <span class="d-flex flex-wrap align-items-center gap-2 w-100 me-2">
                                    <strong>@(dish?.Name ?? "?")</strong>
                                    @if (!string.IsNullOrEmpty(dish?.Category?.Name))
                                    {
                                        <span class="text-muted small">@dish.Category.Name</span>
                                    }
                                    <span class="badge bg-secondary ms-auto">@block.Rows.Count ingredient@(block.Rows.Count == 1 ? "" : "s")</span>
                                </span>
                            </button>
                        </h2>
                        <div id="@collapseId" class="accordion-collapse collapse @(expanded ? "show" : "")" aria-labelledby="@headingId">
                            <div class="accordion-body p-0">
                                <div class="table-responsive">
                                    <table class="table table-sm table-hover align-middle mb-0">
                                        <thead class="table-light">
                                            <tr>
                                                <th>Ingredient</th>
                                                <th class="text-end">Amount per dish</th>
                                                <th class="text-end" style="width: 7rem;">Action</th>
                                            </tr>
                                        </thead>
                                        <tbody>
                                            @foreach (var ri in block.Rows)
                                            {
                                                <tr>
                                                    <td>@ri.Product?.Name <span class="text-muted">(@ri.Product?.Unit)</span></td>
                                                    <td class="text-end font-monospace">@ri.AmountPerDish.ToString("0.###", CultureInfo.InvariantCulture)</td>
                                                    <td class="text-end">
                                                        <form method="post" asp-action="RemoveRecipeIngredient" class="d-inline">
                                                            @Html.AntiForgeryToken()
                                                            <input type="hidden" name="id" value="@ri.Id" />
                                                            <button type="submit" class="btn btn-sm btn-outline-danger">Remove</button>
                                                        </form>
                                                    </td>
                                                </tr>
                                            }
                                        </tbody>
                                    </table>
                                </div>
                            </div>
                        </div>
                    </div>
                }
            </div>
        }
    </div>
</div>

<div class="ff-surface-card mb-4">
    <div class="card-body">
        <h5 class="card-title mb-3">Products</h5>
        <div class="table-responsive">
            <table class="table table-striped align-middle mb-0">
                <thead>
                    <tr>
                        <th>Name</th>
                        <th>Unit</th>
                        <th class="text-end">In Stock</th>
                        <th class="text-end">Reorder Level</th>
                        <th>Status</th>
                    </tr>
                </thead>
                <tbody>
                    @if (!Model.Products.Any())
                    {
                        <tr>
                            <td colspan="5" class="text-center text-muted">No products yet.</td>
                        </tr>
                    }
                    else
                    {
                        @foreach (var p in Model.Products)
                        {
                            var low = p.QuantityInStock <= p.ReorderLevel;
                            <tr>
                                <td>@p.Name</td>
                                <td>@p.Unit</td>
                                <td class="text-end">@p.QuantityInStock.ToString("0.###")</td>
                                <td class="text-end">@p.ReorderLevel.ToString("0.###")</td>
                                <td>
                                    @if (low)
                                    {
                                        <span class="badge bg-warning text-dark">Low stock</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-success">OK</span>
                                    }
                                </td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

<div class="ff-surface-card">
    <div class="card-body">
        <h5 class="card-title mb-3">Recent stock transactions</h5>
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead>
                    <tr>
                        <th>Date</th>
                        <th>Product</th>
                        <th>Type</th>
                        <th class="text-end">Quantity</th>
                        <th>Comment</th>
                    </tr>
                </thead>
                <tbody>
                    @if (!Model.Transactions.Any())
                    {
                        <tr>
                            <td colspan="5" class="text-center text-muted">No transactions yet.</td>
                        </tr>
                    }
                    else
                    {
                        @foreach (var t in Model.Transactions)
                        {
                            <tr>
                                <td>@t.CreatedAt.ToLocalTime()</td>
                                <td>@t.Product?.Name</td>
                                <td>@t.Type</td>
                                <td class="text-end">@t.Quantity.ToString("0.###")</td>
                                <td>@(string.IsNullOrWhiteSpace(t.Comment) ? "-" : t.Comment)</td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>
