@{
    ViewData["Title"] = "Admin Panel";
    var ordersCount = (int)(ViewBag.OrdersCount ?? 0);
    var orderItemsCount = (int)(ViewBag.OrderItemsCount ?? 0);
}

<div class="container py-4">
    <h1 class="mb-3">Admin Panel</h1>

    @if (TempData["AdminMessage"] is string message)
    {
        <div class="alert alert-info">@message</div>
    }

    <div class="row g-3 mb-4">
        <div class="col-md-4">
            <div class="card shadow-sm">
                <div class="card-body">
                    <div class="text-muted small">Orders</div>
                    <div class="fs-4 fw-semibold">@ordersCount</div>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card shadow-sm">
                <div class="card-body">
                    <div class="text-muted small">Order Items</div>
                    <div class="fs-4 fw-semibold">@orderItemsCount</div>
                </div>
            </div>
        </div>
    </div>

    <div class="card border-warning shadow-sm">
        <div class="card-body">
            <h5 class="card-title">Test data tools</h5>
            <p class="text-muted mb-3">
                This action clears only orders and order items. Menu, users, and roles stay untouched.
            </p>
            <form method="post" asp-action="ClearTestOrders">
                @Html.AntiForgeryToken()
                <button type="submit" class="btn btn-outline-danger">
                    Clear test orders
                </button>
            </form>
        </div>
    </div>

    <div class="card shadow-sm mt-3">
        <div class="card-body d-flex justify-content-between align-items-center flex-wrap gap-2">
            <div>
                <h5 class="card-title mb-1">Reports</h5>
                <p class="text-muted mb-0">Sales, top dishes, and low stock overview.</p>
            </div>
            <a class="btn btn-primary" asp-action="Reports">Open reports</a>
        </div>
    </div>

    <div class="card shadow-sm mt-3 border-primary border-opacity-25">
        <div class="card-body d-flex justify-content-between align-items-center flex-wrap gap-2">
            <div>
                <h5 class="card-title mb-1">Purchase lists</h5>
                <p class="text-muted mb-0">Procurement from low stock: suggested quantities and recording deliveries to warehouse.</p>
            </div>
            <a class="btn btn-primary" asp-controller="Purchases" asp-action="Index">Open purchase lists</a>
        </div>
    </div>
</div>
