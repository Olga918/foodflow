@model FoodFlow.ViewModels.AdminReportsViewModel
@{
    ViewData["Title"] = "Admin Reports";
}
<div class="d-flex justify-content-between align-items-center flex-wrap gap-2 mb-3">
    <div>
        <h1 class="ff-title mb-0">Reports</h1>
        <p class="ff-subtitle mb-0">Sales, top dishes, and low stock for the selected period.</p>
    </div>
    <a class="btn btn-outline-secondary" asp-action="Index">Back to admin</a>
</div>
<form method="get" class="row g-3 mb-4 ff-surface-card p-3 p-md-4">
    <div class="col-md-3">
        <label class="form-label" for="fromDate">From</label>
        <input id="fromDate" name="from" type="date" class="form-control" value="@Model.FromDate.ToString("yyyy-MM-dd")" />
    </div>
    <div class="col-md-3">
        <label class="form-label" for="toDate">To</label>
        <input id="toDate" name="to" type="date" class="form-control" value="@Model.ToDate.ToString("yyyy-MM-dd")" />
    </div>
    <div class="col-md-3 align-self-end">
        <button type="submit" class="btn btn-primary">Apply filter</button>
    </div>
    <div class="col-md-3 align-self-end">
        <a class="btn btn-outline-success"
           asp-action="ExportReportsCsv"
           asp-route-from="@Model.FromDate.ToString("yyyy-MM-dd")"
           asp-route-to="@Model.ToDate.ToString("yyyy-MM-dd")">
            Export CSV
        </a>
    </div>
</form>
<div class="row g-3 mb-4">
    <div class="col-md-4">
        <div class="ff-surface-card h-100">
            <div class="card-body">
                <div class="text-muted small">Completed orders</div>
                <div class="fs-4 fw-semibold">@Model.OrdersCount</div>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="ff-surface-card h-100">
            <div class="card-body">
                <div class="text-muted small">Revenue</div>
                <div class="fs-4 fw-semibold">$@Model.TotalRevenue.ToString("0.00")</div>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="ff-surface-card h-100">
            <div class="card-body">
                <div class="text-muted small">Average check</div>
                <div class="fs-4 fw-semibold">$@Model.AverageCheck.ToString("0.00")</div>
            </div>
        </div>
    </div>
</div>
<div class="ff-surface-card overflow-hidden mb-4">
    <div class="card-header">
        <h5 class="mb-0">Sales by day</h5>
    </div>
    <div class="card-body p-0">
        @if (!Model.DailySales.Any())
        {
            <p class="p-3 mb-0 text-muted">No completed orders in selected period.</p>
        }
        else
        {
            <div class="table-responsive">
                <table class="table mb-0">
                    <thead>
                        <tr>
                            <th>Date</th>
                            <th class="text-end">Orders</th>
                            <th class="text-end">Revenue</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var row in Model.DailySales)
                        {
                            <tr>
                                <td>@row.Date.ToString("yyyy-MM-dd")</td>
                                <td class="text-end">@row.OrdersCount</td>
                                <td class="text-end">$@row.Revenue.ToString("0.00")</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    </div>
</div>
<div class="ff-surface-card overflow-hidden mb-4">
    <div class="card-header">
        <h5 class="mb-0">Top dishes</h5>
    </div>
    <div class="card-body p-0">
        @if (!Model.TopMenuItems.Any())
        {
            <p class="p-3 mb-0 text-muted">No completed orders in selected period.</p>
        }
        else
        {
            <div class="table-responsive">
                <table class="table mb-0">
                    <thead>
                        <tr>
                            <th>Dish</th>
                            <th class="text-end">Qty sold</th>
                            <th class="text-end">Revenue</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model.TopMenuItems)
                        {
                            <tr>
                                <td>@item.MenuItemName</td>
                                <td class="text-end">@item.QuantitySold</td>
                                <td class="text-end">$@item.Revenue.ToString("0.00")</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    </div>
</div>
<div class="ff-surface-card overflow-hidden">
    <div class="card-header">
        <h5 class="mb-0">Low stock products</h5>
    </div>
    <div class="card-body p-0">
        @if (!Model.LowStockProducts.Any())
        {
            <p class="p-3 mb-0 text-muted">All products are above reorder level.</p>
        }
        else
        {
            <div class="table-responsive">
                <table class="table mb-0">
                    <thead>
                        <tr>
                            <th>Product</th>
                            <th class="text-end">In stock</th>
                            <th class="text-end">Reorder level</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var product in Model.LowStockProducts)
                        {
                            <tr>
                                <td>@product.ProductName</td>
                                <td class="text-end">@product.QuantityInStock.ToString("0.###") @product.Unit</td>
                                <td class="text-end">@product.ReorderLevel.ToString("0.###") @product.Unit</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    </div>
</div>
